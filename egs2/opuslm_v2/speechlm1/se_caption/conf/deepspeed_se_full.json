{
    "train_micro_batch_size_per_gpu": 1,
    "gradient_accumulation_steps": 1,
    "gradient_clipping": 1.0,
    "bf16": {
        "enabled": true
    },
    "optimizer": {
        "type": "Adam",
        "params": {
            "lr": 1e-05,
            "betas": [
                0.9,
                0.95
            ],
            "eps": 1e-08,
            "weight_decay": 3e-07,
            "adam_w_mode": true
        }
    },
    "zero_optimization": {
        "stage": 2,
        "allgather_partitions": true,
        "allgather_bucket_size": 200000000,
        "reduce_scatter": true,
        "reduce_bucket_size": 200000000,
        "overlap_comm": true,
        "contiguous_gradients": true
    },
    "scheduler": {
        "type": "WarmupCosineLR",
        "params": {
            "warmup_type": "linear",
            "total_num_steps": 13000,
            "warmup_num_steps": 500,
            "cos_min_ratio": 0.3
        }
    },
    "checkpoint": {
        "load_universal": true
    },
    "wall_clock_breakdown": false,
    "steps_per_print": 100
}